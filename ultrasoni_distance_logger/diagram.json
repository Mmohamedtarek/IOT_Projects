{
  "version": 1,
  "author": "Mohamed",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },

    {
      "type": "wokwi-hc-sr04",
      "id": "ultra1",
      "top": -170,
      "left": -180,
      "attrs": {}
    },

    {
      "type": "board-ssd1306",
      "id": "oled1",
      "top": 240,
      "left": 0,
      "attrs": {
        "i2cAddress": "0x3c"
      }
    },

    {
      "type": "wokwi-buzzer",
      "id": "buzz1",
      "top": -100,
      "left": 250,
      "attrs": {}
    },

    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 120,
      "left": 250,
      "attrs": {
        "color": "red"
      }
    },

    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 120,
      "left": 180,
      "rotate": 90,
      "attrs": {
        "value": "220"
      }
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btn1",
      "top": 150,
      "left": -220,
      "attrs": {
        "color": "green"
      }
    }
  ],

  "connections": [

    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "ultra1:VCC", "esp:5V", "red", [] ],
    [ "ultra1:GND", "esp:GND.1", "black", [] ],
    [ "ultra1:TRIG", "esp:5", "green", [] ],
    [ "ultra1:ECHO", "esp:18", "green", [] ],

    [ "oled1:VCC", "esp:3V3", "red", [] ],
    [ "oled1:GND", "esp:GND.1", "black", [] ],
    [ "oled1:SDA", "esp:21", "green", [] ],
    [ "oled1:SCL", "esp:22", "green", [] ],

    [ "buzz1:1", "esp:26", "green", [] ],
    [ "buzz1:2", "esp:GND.1", "black", [] ],

    [ "esp:27", "r1:1", "green", [] ],
    [ "r1:2", "led1:A", "green", [] ],
    [ "led1:C", "esp:GND.1", "black", [] ],

    [ "btn1:1.r", "esp:15", "green", [] ],
    [ "btn1:2.r", "esp:GND.1", "black", [] ]
  ],

  "dependencies": {}
}