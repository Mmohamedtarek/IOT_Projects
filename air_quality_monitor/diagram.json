{
  "version": 1,
  "author": "Mohamed",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },

    {
      "type": "wokwi-gas-sensor",
      "id": "gas1",
      "top": -170,
      "left": -220,
      "attrs": {}
    },

    {
      "type": "wokwi-dht22",
      "id": "dht1",
      "top": -170,
      "left": 220,
      "attrs": {}
    },

    {
      "type": "board-ssd1306",
      "id": "oled1",
      "top": 250,
      "left": 0,
      "attrs": {
        "i2cAddress": "0x3c"
      }
    },

    {
      "type": "wokwi-buzzer",
      "id": "buzz1",
      "top": 50,
      "left": 250,
      "attrs": {}
    },

    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 120,
      "left": 250,
      "attrs": {
        "color": "red"
      }
    },

    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 120,
      "left": 180,
      "rotate": 90,
      "attrs": {
        "value": "220"
      }
    }
  ],

  "connections": [

    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["oled1:VCC", "esp:3V3", "red", []],
    ["oled1:GND", "esp:GND.1", "black", []],
    ["oled1:SDA", "esp:21", "green", []],
    ["oled1:SCL", "esp:22", "green", []],

    ["dht1:VCC", "esp:3V3", "red", []],
    ["dht1:GND", "esp:GND.1", "black", []],
    ["dht1:SDA", "esp:4", "green", []],

    ["gas1:VCC", "esp:5V", "red", []],
    ["gas1:GND", "esp:GND.1", "black", []],
    ["gas1:AOUT", "esp:34", "green", []],

    ["buzz1:1", "esp:26", "green", []],
    ["buzz1:2", "esp:GND.1", "black", []],

    ["esp:27", "r1:1", "green", []],
    ["r1:2", "led1:A", "green", []],
    ["led1:C", "esp:GND.1", "black", []]
  ],

  "dependencies": {}
}