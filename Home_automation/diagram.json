{
  "version": 1,
  "author": "Mohamed",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },

    {
      "type": "board-ssd1306",
      "id": "oled1",
      "top": 260,
      "left": 0,
      "attrs": {
        "i2cAddress": "0x3c"
      }
    },

    {
      "type": "wokwi-relay-module",
      "id": "relay1",
      "top": -120,
      "left": 200,
      "attrs": {}
    },

    {
      "type": "wokwi-relay-module",
      "id": "relay2",
      "top": -10,
      "left": 200,
      "attrs": {}
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btn1",
      "top": -120,
      "left": -220,
      "attrs": {
        "color": "green"
      }
    },

    {
      "type": "wokwi-pushbutton",
      "id": "btn2",
      "top": -10,
      "left": -220,
      "attrs": {
        "color": "blue"
      }
    },

    {
      "type": "wokwi-led",
      "id": "led1",
      "top": -120,
      "left": 420,
      "attrs": {
        "color": "yellow"
      }
    },

    {
      "type": "wokwi-led",
      "id": "led2",
      "top": -10,
      "left": 420,
      "attrs": {
        "color": "red"
      }
    },

    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": -120,
      "left": 350,
      "rotate": 90,
      "attrs": {
        "value": "220"
      }
    },

    {
      "type": "wokwi-resistor",
      "id": "r2",
      "top": -10,
      "left": 350,
      "rotate": 90,
      "attrs": {
        "value": "220"
      }
    }
  ],

  "connections": [

    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "oled1:VCC", "esp:3V3", "red", [] ],
    [ "oled1:GND", "esp:GND.1", "black", [] ],
    [ "oled1:SDA", "esp:21", "green", [] ],
    [ "oled1:SCL", "esp:22", "green", [] ],

    [ "relay1:VCC", "esp:3V3", "red", [] ],
    [ "relay1:GND", "esp:GND.1", "black", [] ],
    [ "relay1:IN", "esp:26", "green", [] ],

    [ "relay2:VCC", "esp:3V3", "red", [] ],
    [ "relay2:GND", "esp:GND.1", "black", [] ],
    [ "relay2:IN", "esp:25", "green", [] ],

    [ "btn1:1.r", "esp:15", "green", [] ],
    [ "btn1:2.r", "esp:GND.1", "black", [] ],

    [ "btn2:1.r", "esp:4", "green", [] ],
    [ "btn2:2.r", "esp:GND.1", "black", [] ],

    [ "esp:27", "r1:1", "green", [] ],
    [ "r1:2", "led1:A", "green", [] ],
    [ "led1:C", "esp:GND.1", "black", [] ],

    [ "esp:14", "r2:1", "green", [] ],
    [ "r2:2", "led2:A", "green", [] ],
    [ "led2:C", "esp:GND.1", "black", [] ]
  ],

  "dependencies": {}
}