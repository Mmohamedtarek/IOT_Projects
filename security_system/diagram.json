{
  "version": 1,
  "author": "Mohamed",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-c-v4",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },

    {
      "type": "wokwi-pir-motion-sensor",
      "id": "pir1",
      "top": -150,
      "left": -180,
      "attrs": {}
    },

    {
      "type": "wokwi-buzzer",
      "id": "buzz1",
      "top": -100,
      "left": 220,
      "attrs": {}
    },

    {
      "type": "wokwi-led",
      "id": "led1",
      "top": 120,
      "left": 250,
      "attrs": {
        "color": "red"
      }
    },

    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 120,
      "left": 180,
      "rotate": 90,
      "attrs": {
        "value": "220"
      }
    },
    {
    "type": "wokwi-pushbutton",
    "id": "btn1",
    "top": 180,
    "left": -200,
    "attrs": {
    "color": "green"
  }
}
  ],

  "connections": [

    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "pir1:VCC", "esp:3V3", "red", [] ],
    [ "pir1:GND", "esp:GND.1", "black", [] ],
    [ "pir1:OUT", "esp:13", "green", [] ],

    [ "buzz1:1", "esp:26", "green", [] ],
    [ "buzz1:2", "esp:GND.1", "black", [] ],

    [ "esp:27", "r1:1", "green", [] ],
    [ "r1:2", "led1:A", "green", [] ],
    [ "led1:C", "esp:GND.1", "black", [] ],
    [ "btn1:1.r", "esp:15", "green", [] ],
    [ "btn1:2.r", "esp:GND.1", "black", [] ]
  ],

  "dependencies": {}
}